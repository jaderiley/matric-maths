    {
      "id": "functions-12",
      "difficulty": 3,
      "context": "Given: $f(x)=x^2-3x+2$",
      "svg": null,
      "archetype": "fun-level4-tangent",
      "parts": [
        {
          "q": "Determine the value(s) of $m$ for which the line $y=mx-2$ is a tangent to $f$.",
          "marks": 4,
          "solution": [
            "For a tangent: $x^2-3x+2=mx-2$",
            "$x^2-(3+m)x+4=0$ must have equal roots, so $\\Delta=0$",
            "$(3+m)^2-4(1)(4)=0\\Rightarrow (3+m)^2=16$",
            "$3+m=\\pm 4\\Rightarrow m=1$ or $m=-7$"
          ],
          "answer": "$m=1$ or $m=-7$"
        },
        {
          "q": "For which values of $m$ will the line $y=mx-2$ cut $f$ at two distinct points?",
          "marks": 3,
          "solution": [
            "Two distinct points: $\\Delta>0$",
            "$(3+m)^2-16>0\\Rightarrow (3+m)^2>16$",
            "$3+m>4$ or $3+m<-4$",
            "$m>1$ or $m<-7$"
          ],
          "answer": "$m>1$ or $m<-7$"
        }
      ]
    },
    {
      "id": "functions-13",
      "difficulty": 3,
      "context": "Given: $f(x)=-x^2+6x+1$ and the straight line $g(x)=2x+3$.",
      "svg": null,
      "archetype": "fun-level4-tangent",
      "parts": [
        {
          "q": "Write down the coordinates of the turning point of $f$.",
          "marks": 2,
          "solution": [
            "$x=-\\dfrac{b}{2a}=-\\dfrac{6}{2(-1)}=3$",
            "$f(3)=-9+18+1=10$",
            "Turning point $(3;10)$"
          ],
          "answer": "$(3;10)$"
        },
        {
          "q": "Given $k(x)=f(x+m)$, determine the value of $m$ for which $g$ is a tangent to $k$.",
          "marks": 5,
          "solution": [
            "$k(x)=-(x+m)^2+6(x+m)+1=-x^2+(6-2m)x+(-m^2+6m+1)$",
            "Tangent: $k(x)=2x+3$ has equal roots",
            "$-x^2+(4-2m)x+(-m^2+6m-2)=0$, i.e. $x^2-(4-2m)x+(m^2-6m+2)=0$",
            "$\\Delta=0$: $(4-2m)^2-4(m^2-6m+2)=0$",
            "$16-16m+4m^2-4m^2+24m-8=0\\Rightarrow 8m+8=0$",
            "$m=-1$"
          ],
          "answer": "$m=-1$"
        }
      ]
    }
  ]
}
